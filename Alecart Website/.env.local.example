# Copy this file to .env.local and fill in your values.
# Never share or commit .env.local — it contains your password.

# Your Gmail address
GMAIL_USER=AlecartSolutions@gmail.com

# Gmail App Password (NOT your regular Gmail password)
# How to get one: https://myaccount.google.com/apppasswords
# 1. Go to your Google Account → Security
# 2. Enable 2-Step Verification (required)
# 3. Search for "App passwords" → Create one named "Website"
# 4. Copy the 16-character password and paste it below (no spaces)
GMAIL_APP_PASSWORD=your-16-character-app-password-here
